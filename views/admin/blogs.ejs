<div id="alertBox"></div>

<div class="card" style="margin-bottom:20px;">
  <div class="card-body" style="padding:16px 20px;">
    <div class="search-bar" style="margin-bottom:0;">
      <div class="search-input-wrap">
        <i class="fas fa-search"></i>
        <input type="text" id="searchInput" class="form-control" placeholder="Search posts...">
      </div>
      <select id="statusFilter" class="form-control" style="max-width:160px;">
        <option value="">All Status</option>
        <option value="published">Published</option>
        <option value="draft">Draft</option>
      </select>
      <button class="btn btn-secondary btn-sm" onclick="loadBlogs()"><i class="fas fa-filter"></i> Filter</button>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body" style="padding:0;">
    <table class="table">
      <thead>
        <tr>
          <th>Title</th><th>Author</th><th>Category</th><th>Status</th><th>Views</th><th>Date</th><th>Actions</th>
        </tr>
      </thead>
      <tbody id="blogsTable">
        <tr><td colspan="7"><div class="loading-spinner"><div class="spinner"></div></div></td></tr>
      </tbody>
    </table>
  </div>
</div>
