<nav class="landing-nav" id="publicNav">
  <a href="/" class="logo"><i class="fas fa-dumbbell"></i> FitGym</a>
  <div class="landing-nav-links">
    <a href="/blog">Blog</a>
    <a href="/login" class="btn" style="border:1.5px solid var(--accent-gold);color:var(--accent-gold);padding:7px 16px;border-radius:7px;">Login</a>
    <a href="/register" class="btn btn-primary" style="padding:7px 16px;">Join Now</a>
  </div>
</nav>

<div style="max-width:820px;margin:0 auto;padding:40px 24px;" id="blogDetailWrap">
  <div class="loading-spinner"><div class="spinner"></div></div>
</div>

<script src="/js/api.js"></script>
<script src="/js/auth.js"></script>
<script src="/js/nav.js"></script>
<script>
  // Update nav if logged in
  const _user = getUser();
  if (_user) {
    document.querySelector('.landing-nav-links').innerHTML = `
      <a href="/blog">Blog</a>
      <a href="${getDashboardUrl(_user.role)}" class="btn btn-primary" style="padding:7px 16px;">
        <i class="fas fa-tachometer-alt"></i> Dashboard
      </a>
    `;
  }

  (async () => {
    const params = new URLSearchParams(window.location.search);
    const id = params.get('id');
    const wrap = document.getElementById('blogDetailWrap');

    if (!id) {
      wrap.innerHTML = `<div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> No blog post specified.</div>
        <a href="/blog" class="btn btn-secondary" style="margin-top:16px;"><i class="fas fa-arrow-left"></i> Back to Blog</a>`;
      return;
    }

    try {
      // Increment view count
      fetch('/api/blogs/' + id + '/view', { method: 'POST' }).catch(() => {});

      const res = await fetch('/api/blogs/' + id);
      if (!res.ok) throw new Error('Post not found');
      const { blog: b } = await res.json();

      wrap.innerHTML = `
        <a href="/blog" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-secondary);font-size:0.875rem;text-decoration:none;margin-bottom:28px;">
          <i class="fas fa-arrow-left"></i> Back to Blog
        </a>

        ${b.category ? `<div style="margin-bottom:12px;"><span style="background:var(--accent-gold);color:white;font-size:0.75rem;font-weight:600;padding:4px 12px;border-radius:20px;text-transform:uppercase;letter-spacing:0.05em;">${b.category}</span></div>` : ''}

        <h1 style="font-size:2rem;font-weight:700;line-height:1.3;margin-bottom:16px;color:var(--text-primary);">${b.title}</h1>

        <div style="display:flex;align-items:center;gap:20px;color:var(--text-secondary);font-size:0.875rem;margin-bottom:32px;padding-bottom:24px;border-bottom:1px solid var(--border-color);">
          <div style="display:flex;align-items:center;gap:8px;">
            <div style="width:32px;height:32px;border-radius:50%;background:var(--accent-gold);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:0.85rem;">
              ${(b.author_name || 'A').charAt(0).toUpperCase()}
            </div>
            <span>${b.author_name || 'FitGym'}</span>
          </div>
          <div><i class="fas fa-calendar" style="color:var(--accent-gold);margin-right:5px;"></i>${new Date(b.created_at).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}</div>
          <div><i class="fas fa-eye" style="color:var(--accent-gold);margin-right:5px;"></i>${b.views || 0} views</div>
        </div>

        <div style="font-size:1rem;line-height:1.8;color:var(--text-primary);white-space:pre-wrap;">${b.content || '<em style="color:var(--text-secondary);">No content yet.</em>'}</div>

        <div style="margin-top:40px;padding-top:24px;border-top:1px solid var(--border-color);">
          <a href="/blog" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to Blog</a>
        </div>
      `;
    } catch (err) {
      wrap.innerHTML = `<div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> ${err.message}</div>
        <a href="/blog" class="btn btn-secondary" style="margin-top:16px;"><i class="fas fa-arrow-left"></i> Back to Blog</a>`;
    }
  })();
</script>
