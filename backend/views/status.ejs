<!DOCTYPE html>
<html>
  <head>
    <%- include("partials/head.ejs") %>
    <title>FitGym - <%= status %></title>
  </head>
  <body>
    <main>
      <%- include("partials/header.ejs") %>
      <section class="page-content">
        <div class="responsive-half margin-auto">
          <h2 class="section-heading"><%= status %></h2>
          <% if (typeof message !== "undefined") { %>
            <p><%= message %></p>
          <% } %>
          <br />
          <a href="javascript:history.back()" class="link-button">Go Back</a>
        </div>
      </section>
      <%- include("partials/footer.ejs") %>
    </main>
  </body>
</html>
