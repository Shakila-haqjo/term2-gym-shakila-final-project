<!DOCTYPE html>
<html>
  <head>
    <%- include("partials/head.ejs") %>
    <title>FitGym - <%= blog.title %></title>
  </head>
  <body>
    <main>
      <%- include("partials/header.ejs") %>
      <section class="page-content">
        <a href="/blog" class="link-button" style="width:auto; padding:8px 20px; margin-bottom:20px; display:inline-block;">&larr; Back to Blog</a>

        <article>
          <h2 class="section-heading"><%= blog.title %></h2>
          <p style="font-size:13px; color:#888; margin-bottom:20px;">
            By <strong><%= blog.author_name || 'Unknown' %></strong>
            <% if (blog.category) { %> &nbsp;&bull;&nbsp; <%= blog.category %><% } %>
            &nbsp;&bull;&nbsp; <%= formatDate(blog.created_at) %>
            &nbsp;&bull;&nbsp; <span class="badge <%= blog.status %>"><%= blog.status %></span>
          </p>
          <div style="font-size:15px; line-height:1.8; white-space:pre-wrap;"><%- blog.content || '' %></div>
        </article>
      </section>
      <%- include("partials/footer.ejs") %>
    </main>
  </body>
</html>
