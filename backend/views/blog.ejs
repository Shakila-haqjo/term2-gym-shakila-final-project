<nav class="landing-nav" id="publicNav">
  <a href="/" class="logo"><i class="fas fa-dumbbell"></i> FitGym</a>
  <div class="landing-nav-links">
    <a href="/blog" style="color:var(--accent-gold);">Blog</a>
    <a href="/login" class="btn" style="border:1.5px solid var(--accent-gold);color:var(--accent-gold);padding:7px 16px;border-radius:7px;">Login</a>
    <a href="/register" class="btn btn-primary" style="padding:7px 16px;">Join Now</a>
  </div>
</nav>

<div style="max-width:1100px;margin:0 auto;padding:40px 24px;">
  <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:32px;">
    <div>
      <h1 style="font-size:2rem;font-weight:700;margin-bottom:8px;">Fitness Blog</h1>
      <p style="color:var(--text-secondary);">Tips, guides, and stories from our community</p>
    </div>
    <a id="writePostBtn" href="/member/create-blog" class="btn btn-primary" style="display:none;align-items:center;gap:8px;padding:10px 20px;">
      <i class="fas fa-pen"></i> Write a Post
    </a>
  </div>

  <div class="search-bar" style="margin-bottom:32px;">
    <div class="search-input-wrap">
      <i class="fas fa-search"></i>
      <input type="text" id="searchInput" class="form-control" placeholder="Search articles...">
    </div>
    <select id="categoryFilter" class="form-control" style="max-width:200px;">
      <option value="">All Categories</option>
      <option value="Fitness Tips">Fitness Tips</option>
      <option value="Nutrition">Nutrition</option>
      <option value="Wellness">Wellness</option>
      <option value="Science">Science</option>
      <option value="Motivation">Motivation</option>
    </select>
  </div>

  <div id="blogGrid" class="blog-grid">
    <div class="loading-spinner"><div class="spinner"></div></div>
  </div>
</div>

<script src="/js/api.js"></script>
<script src="/js/auth.js"></script>
<script src="/js/nav.js"></script>
<script src="/js/blog.js"></script>
<script>
  const _user = getUser();
  if (_user) {
    const nav = document.getElementById('publicNav');
    if (nav) {
      nav.querySelector('.landing-nav-links').innerHTML = `
        <a href="/timetable"><i class="fas fa-calendar-alt"></i> Timetable</a>
        <a href="/blog" style="color:var(--accent-gold);"><i class="fas fa-blog"></i> Blog</a>
        <a href="${getDashboardUrl(_user.role)}" class="btn btn-primary" style="padding:7px 16px;">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
      `;
    }
  }
</script>
