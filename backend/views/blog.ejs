<!DOCTYPE html>
<html>
  <head>
    <%- include("partials/head.ejs") %>
    <title>FitGym - Blog</title>
  </head>
  <body>
    <main>
      <%- include("partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Blog</h2>

        <% if (blogs.length === 0) { %>
          <p>No blog posts yet.</p>
        <% } else { %>
          <div class="blog-list">
            <% for (const blog of blogs) { %>
              <article class="blog-card">
                <h3><%= blog.title %></h3>
                <p class="meta">
                  By <%= blog.author_name || 'Unknown' %>
                  <% if (blog.category) { %> &nbsp;&bull;&nbsp; <%= blog.category %><% } %>
                  &nbsp;&bull;&nbsp; <%= formatDate(blog.created_at) %>
                </p>
                <p><%= blog.content ? blog.content.slice(0, 200) : '' %><%= blog.content && blog.content.length > 200 ? '...' : '' %></p>
              </article>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("partials/footer.ejs") %>
    </main>
  </body>
</html>
