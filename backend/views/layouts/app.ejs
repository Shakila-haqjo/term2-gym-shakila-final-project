<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'FitGym' %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <script>tailwind = { config: { corePlugins: { preflight: false } } };</script>
  <script src="https://cdn.tailwindcss.com"></script>
  <% if (locals.extraHead) { %><%- extraHead %><% } %>
</head>
<body>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <header class="top-header">
        <div class="header-left">
          <button class="hamburger" id="hamburgerBtn"><span></span><span></span><span></span></button>
          <span class="page-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></span>
        </div>
        <div class="header-right" style="display:flex;align-items:center;gap:12px;">
          <span id="headerDate" style="font-size:0.85rem; color:var(--text-secondary);"></span>
          <% if (locals.headerBtn) { %><%- headerBtn %><% } %>
        </div>
      </header>
      <div class="page-content">
        <%- body %>
      </div>
    </div>
  </div>
  <div id="toast-container"></div>
  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/nav.js"></script>
  <% if (locals.pageScript) { %>
  <script src="<%= pageScript %>"></script>
  <% } %>
</body>
</html>
