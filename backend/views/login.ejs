<!DOCTYPE html>
<html>
  <head>
    <%- include("partials/head.ejs") %>
    <title>FitGym - Login</title>
  </head>
  <body>
    <main>
      <%- include("partials/header.ejs") %>
      <section class="page-content">
        <form action="/authenticate" method="post" class="form-grid responsive-half margin-auto">
          <h2 class="two-col">Login</h2>

          <% if (error) { %>
            <p class="two-col" style="color:darkred;"><%= error %></p>
          <% } %>

          <label for="email">Email:</label>
          <input type="email" name="email" id="email" required />

          <label for="password">Password:</label>
          <input type="password" name="password" id="password" required />

          <a href="/" class="link-button two-col">Back to Home</a>
          <input type="submit" value="Login" class="two-col" />

          <span class="two-col">New member? <a href="/authenticate/register">Register here</a></span>
        </form>
      </section>
      <%- include("partials/footer.ejs") %>
    </main>
  </body>
</html>
