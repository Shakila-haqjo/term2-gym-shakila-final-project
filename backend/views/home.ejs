<script src="/js/auth.js"></script>
<script>
  const user = getUser();
  if (user) {
    const navLinks = document.querySelector('.landing-nav-links');
    if (navLinks) {
      navLinks.innerHTML = `
        <a href="/timetable"><i class="fas fa-calendar-alt"></i> Timetable</a>
        <a href="/blog"><i class="fas fa-blog"></i> Blog</a>
        <a href="${getDashboardUrl(user.role)}" class="btn btn-primary" style="padding:8px 16px;">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
      `;
    }
  }

  function formatDate(d) {
    if (!d) return '-';
    return new Date(d + (d.includes('T') ? '' : 'T00:00:00')).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }
  function formatTime(t) {
    if (!t) return '-';
    const [h, m] = t.split(':');
    const hr = parseInt(h), ampm = hr >= 12 ? 'PM' : 'AM';
    return `${hr % 12 || 12}:${m} ${ampm}`;
  }

  async function loadHomeSessions() {
    const grid = document.getElementById('homeSessionGrid');
    grid.innerHTML = '<div class="loading-spinner" style="grid-column:1/-1;"><div class="spinner"></div></div>';
    try {
      const res = await fetch('/api/sessions/public?upcoming=true');
      const data = await res.json();
      const sessions = (data.sessions || []).slice(0, 6);
      if (!sessions.length) {
        grid.innerHTML = '<p style="text-align:center;color:var(--text-secondary);grid-column:1/-1;">No upcoming sessions right now.</p>';
        return;
      }
      grid.innerHTML = sessions.map(s => {
        const pct = Math.round((s.booked_count / s.max_participants) * 100);
        const fillClass = pct >= 90 ? 'danger' : pct >= 70 ? 'warning' : '';
        return `
          <div class="session-card">
            <div class="session-card-header">
              <div class="activity-badge">${s.activity_name || 'General'}</div>
              <h3>${s.name}</h3>
            </div>
            <div class="session-card-body">
              <div class="session-meta">
                <div class="session-meta-item"><i class="fas fa-calendar"></i> ${formatDate(s.date)}</div>
                <div class="session-meta-item"><i class="fas fa-clock"></i> ${formatTime(s.time)} (${s.duration_minutes} min)</div>
                <div class="session-meta-item"><i class="fas fa-map-marker-alt"></i> ${s.location_name || 'TBD'}</div>
                <div class="session-meta-item"><i class="fas fa-user-tie"></i> ${s.trainer_name || 'TBD'}</div>
              </div>
              <div class="session-capacity">
                <div style="display:flex;justify-content:space-between;font-size:0.8rem;color:var(--text-secondary);">
                  <span><i class="fas fa-users"></i> ${s.booked_count}/${s.max_participants} booked</span>
                  <span>${s.max_participants - s.booked_count} spots left</span>
                </div>
                <div class="capacity-bar"><div class="capacity-fill ${fillClass}" style="width:${pct}%"></div></div>
              </div>
              <a href="/register" class="btn btn-primary w-100" style="margin-top:12px;">
                <i class="fas fa-user-plus"></i> Sign Up to Book
              </a>
            </div>
          </div>`;
      }).join('');
    } catch {
      grid.innerHTML = '<p style="text-align:center;color:var(--text-secondary);grid-column:1/-1;">Could not load sessions.</p>';
    }
  }

  async function loadHomeBlogs() {
    const grid = document.getElementById('homeBlogGrid');
    grid.innerHTML = '<div class="loading-spinner" style="grid-column:1/-1;"><div class="spinner"></div></div>';
    try {
      const res = await fetch('/api/blogs?status=published');
      const data = await res.json();
      const blogs = (data.blogs || []).slice(0, 3);
      if (!blogs.length) {
        grid.innerHTML = '<p style="text-align:center;color:var(--text-secondary);grid-column:1/-1;">No blog posts yet.</p>';
        return;
      }
      grid.innerHTML = blogs.map(b => `
        <div class="blog-card">
          <div class="blog-card-body">
            <div class="blog-category">${b.category || 'General'}</div>
            <h3 class="blog-card-title"><a href="/blog-detail?id=${b.id}">${b.title}</a></h3>
            <div class="blog-card-meta">
              <span><i class="fas fa-user"></i> ${b.author_name}</span>
              <span><i class="fas fa-eye"></i> ${b.views || 0}</span>
              <span><i class="fas fa-calendar"></i> ${formatDate(b.created_at)}</span>
            </div>
          </div>
        </div>`).join('');
    } catch {
      grid.innerHTML = '<p style="text-align:center;color:var(--text-secondary);grid-column:1/-1;">Could not load posts.</p>';
    }
  }

  loadHomeSessions();
  loadHomeBlogs();
</script>
