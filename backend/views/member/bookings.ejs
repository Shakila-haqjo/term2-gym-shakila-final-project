<!DOCTYPE html>
<html>
  <head>
    
    <%- include("../partials/head.ejs") %>
    <title>FitGym - My Bookings</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">My Bookings</h2>
        <a href="/member/sessions" class="link-button" style="width:auto; padding:8px 20px; margin-bottom:15px; display:inline-block;">Browse Sessions</a>

        <% if (bookings.length === 0) { %>
          <p>You have no bookings yet.</p>
        <% } else { %>
          <div class="data-list cols-6" style="margin-top:15px;">
            <span class="data-list-heading">Session</span>
            <span class="data-list-heading">Date</span>
            <span class="data-list-heading">Time</span>
            <span class="data-list-heading">Activity</span>
            <span class="data-list-heading">Status</span>
            <span class="data-list-heading">Actions</span>
            <% for (const b of bookings) { %>
              <span><%= b.session_name %></span>
              <span><%= formatDate(b.session_date) %></span>
              <span><%= b.session_time ? b.session_time.slice(0,5) : '' %></span>
              <span><%= b.activity_name || 'N/A' %></span>
              <span class="badge <%= b.status %>"><%= b.status %></span>
              <div>
                <% if (b.status === 'confirmed') { %>
                  <form action="/member/bookings/<%= b.id %>/cancel" method="post">
                    <input type="submit" value="Cancel" class="danger" />
                  </form>
                <% } %>
              </div>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
