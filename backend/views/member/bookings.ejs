<div class="card" style="margin-bottom:16px;">
  <div class="card-body" style="padding:12px 20px;display:flex;justify-content:flex-end;">
    <a href="/member/sessions" class="btn btn-sm btn-primary"><i class="fas fa-plus"></i> Book Session</a>
  </div>
</div>

<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('upcoming', this)">Upcoming</button>
  <button class="tab-btn" onclick="switchTab('past', this)">Past</button>
  <button class="tab-btn" onclick="switchTab('all', this)">All</button>
</div>

<div class="card">
  <div class="card-body" style="padding:0;">
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Session</th><th>Activity</th><th>Date & Time</th><th>Location</th><th>Trainer</th><th>Status</th><th>Action</th>
          </tr>
        </thead>
        <tbody id="bookingsTable">
          <tr><td colspan="7"><div class="loading-spinner"><div class="spinner"></div></div></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
