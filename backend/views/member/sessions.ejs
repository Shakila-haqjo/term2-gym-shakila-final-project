<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Browse Sessions</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Browse Upcoming Sessions</h2>

        <form action="/member/sessions" method="get" class="search-form">
          <input type="text" name="search" placeholder="Search sessions..." value="<%= search %>" />
          <input type="date" name="date" value="<%= dateFilter %>" />
          <input type="submit" value="Filter" style="width:auto;" />
          <a href="/member/sessions" class="link-button" style="width:auto;">Clear</a>
        </form>

        <% if (sessions.length === 0) { %>
          <p>No upcoming sessions found.</p>
        <% } else { %>
          <div class="card-list">
            <% for (const session of sessions) { %>
              <article class="card">
                <h3><%= session.name %></h3>
                <p>Date: <strong><%= session.date %></strong> at <strong><%= session.time ? session.time.slice(0,5) : '' %></strong></p>
                <p>Activity: <%= session.activity_name || 'N/A' %></p>
                <p>Location: <%= session.location_name || 'N/A' %></p>
                <p>Trainer: <%= session.trainer_name || 'N/A' %></p>
                <p>Duration: <%= session.duration_minutes %> min &nbsp;|&nbsp; Max: <%= session.max_participants %> &nbsp;|&nbsp; Booked: <%= session.booked_count %></p>
                <% if (session.description) { %><p><%= session.description %></p><% } %>
                <% if (session.booked_count < session.max_participants) { %>
                  <form action="/member/sessions/<%= session.id %>/book" method="post">
                    <input type="submit" value="Book Session" />
                  </form>
                <% } else { %>
                  <span class="badge cancelled">Session Full</span>
                <% } %>
              </article>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
