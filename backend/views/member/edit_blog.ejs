<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Edit Blog Post</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <form action="/member/blog/<%= blog.id %>" method="post" class="form-grid responsive-half margin-auto">
          <h2 class="two-col">Edit Blog Post</h2>

          <% if (error) { %>
            <p class="two-col" style="color:darkred;"><%= error %></p>
          <% } %>

          <label for="title">Title:</label>
          <input type="text" name="title" id="title" value="<%= blog.title %>" required />

          <label for="category">Category:</label>
          <input type="text" name="category" id="category" value="<%= blog.category || '' %>" />

          <label for="content">Content:</label>
          <textarea name="content" id="content" style="height:10em;"><%= blog.content || '' %></textarea>

          <label for="status">Status:</label>
          <select name="status" id="status">
            <option value="draft"      <%= blog.status === 'draft'      ? 'selected' : '' %>>Draft</option>
            <option value="published"  <%= blog.status === 'published'  ? 'selected' : '' %>>Published</option>
          </select>

          <a href="/member/blog" class="link-button two-col">Cancel</a>
          <input type="submit" name="action" value="update" class="two-col" />
          <input type="submit" name="action" value="delete" class="two-col danger" />
        </form>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
