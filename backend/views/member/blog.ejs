<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Blog</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Blog</h2>
        <a href="/member/blog/create" class="link-button" style="width:auto; padding:8px 20px; margin-bottom:15px; display:inline-block;">Write a Post</a>

        <% if (blogs.length === 0) { %>
          <p>No blog posts yet. Be the first to write one!</p>
        <% } else { %>
          <div class="blog-list">
            <% for (const blog of blogs) { %>
              <article class="blog-card">
                <h3><%= blog.title %></h3>
                <p class="meta">
                  By <%= blog.author_name || 'Unknown' %>
                  <% if (blog.category) { %> &nbsp;&bull;&nbsp; <%= blog.category %><% } %>
                  &nbsp;&bull;&nbsp; <%= blog.created_at ? blog.created_at.slice(0,10) : '' %>
                  &nbsp;&bull;&nbsp; <span class="badge <%= blog.status %>"><%= blog.status %></span>
                </p>
                <p><%= blog.content ? blog.content.slice(0, 250) : '' %><%= blog.content && blog.content.length > 250 ? '...' : '' %></p>
              </article>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
