<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Blog</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Blog</h2>
        <a href="/member/blog/create" class="link-button" style="width:auto; padding:8px 20px; margin-bottom:15px; display:inline-block;">Write a Post</a>

        <% if (blogs.length === 0) { %>
          <p>No blog posts yet. Be the first to write one!</p>
        <% } else { %>
          <div class="data-list cols-6" style="margin-top:15px;">
            <span class="data-list-heading">Title</span>
            <span class="data-list-heading">Category</span>
            <span class="data-list-heading">Status</span>
            <span class="data-list-heading">Created</span>
            <span class="data-list-heading">Actions</span>
            <span class="data-list-heading"></span>
            <% for (const blog of blogs) { %>
              <span><%= blog.title %></span>
              <span><%= blog.category || 'N/A' %></span>
              <span class="badge <%= blog.status %>"><%= blog.status %></span>
              <span><%= formatDate(blog.created_at) %></span>
              <span style="display:flex; gap:6px;">
                <a href="/blog/<%= blog.id %>" class="link-button" style="width:auto; padding:5px 12px;">Read</a>
                <a href="/member/blog/<%= blog.id %>/edit" class="link-button" style="width:auto; padding:5px 12px;">Edit</a>
              </span>
              <form action="/member/blog/<%= blog.id %>" method="post">
                <input type="hidden" name="action" value="delete" />
                <input type="submit" value="Delete" class="danger"
                  onclick="return confirm('Are you sure you want to delete &quot;<%= blog.title %>&quot;? This cannot be undone.')" />
              </form>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
