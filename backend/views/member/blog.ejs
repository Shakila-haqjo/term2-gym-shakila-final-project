<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Blog</title>
  </head>

  <body class="member-page">
    <main>
      <%- include("../partials/header.ejs") %>

      <section class="page-content">

        <h2 class="section-heading">Blog</h2>

        <!-- Create button -->
        <a href="/member/blog/create" 
           class="link-button" 
           style="width:auto; padding:8px 20px; margin-bottom:15px; display:inline-block;">
          Write a Post
        </a>

        <% if (blogs.length === 0) { %>
          <p>No blog posts yet. Be the first to write one!</p>
        <% } else { %>

          <!-- ✅ FIX: Use ONLY blog-grid (remove stats-row & table layout) -->
          <div class="blog-grid">

            <% for (const blog of blogs) { %>

              <div class="blog-card">

                <!-- Title -->
                <h3 class="blog-title"><%= blog.title %></h3>

                <!-- Meta -->
                <!-- <p class="blog-meta">
                  Category: <%= blog.category || 'N/A' %>
                </p> -->

                <!-- Date (only date, no time) -->
                <p class="blog-date">
                  Created: <%= formatDate(blog.created_at) %>
                </p>

                <!-- Actions -->
                <div class="blog-actions">

                  <a href="/blog/<%= blog.id %>" class="link-button">
                    Read
                  </a>

                  <form action="/member/blog/<%= blog.id %>" method="post">
                    <input type="hidden" name="action" value="delete" />

                    <input 
                      type="submit" 
                      value="Delete" 
                      class="danger"
                      data-confirm="Are you sure you want to delete '<%= blog.title %>'?"
                    />
                  </form>

                </div>

              </div>

            <% } %>

          </div>

        <% } %>

      </section>

      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>