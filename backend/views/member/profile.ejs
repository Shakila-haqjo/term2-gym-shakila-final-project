<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - My Profile</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <form action="/member/profile" method="post" class="form-grid responsive-half margin-auto">
          <h2 class="two-col">My Profile</h2>

          <% if (error) { %>
            <p class="two-col" style="color:darkred;"><%= error %></p>
          <% } %>
          <% if (success) { %>
            <p class="two-col" style="color:green;"><%= success %></p>
          <% } %>

          <label for="name">Full Name:</label>
          <input type="text" name="name" id="name" value="<%= user.name %>" required />

          <label>Email:</label>
          <span style="font-size:14px; color:#555;"><%= user.email %></span>

          <label for="phone">Phone:</label>
          <input type="text" name="phone" id="phone" value="<%= user.phone || '' %>" />

          <label for="address">Address:</label>
          <input type="text" name="address" id="address" value="<%= user.address || '' %>" />

          <label for="password">New Password:</label>
          <input type="password" name="password" id="password" placeholder="Leave blank to keep current" />

          <a href="/member/dashboard" class="link-button two-col">Cancel</a>
          <input type="submit" value="Save Changes" class="two-col" />
        </form>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
