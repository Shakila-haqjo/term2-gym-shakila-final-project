<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Member Dashboard</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Welcome, <%= authenticatedUser.name %>!</h2>

        <h3 style="margin: 15px 0 5px;">Your Upcoming Bookings</h3>
        <% if (bookings.length === 0) { %>
          <p>You have no upcoming bookings. <a href="/member/sessions">Browse sessions</a> to book one.</p>
        <% } else { %>
          <div class="card-list">
            <% for (const b of bookings) { %>
              <article class="card">
                <h3><%= b.session_name %></h3>
                <p>Date: <strong><%= b.session_date %></strong> at <strong><%= b.session_time ? b.session_time.slice(0,5) : '' %></strong></p>
                <p>Activity: <%= b.activity_name || 'N/A' %></p>
                <p>Location: <%= b.location_name || 'N/A' %></p>
                <p>Trainer: <%= b.trainer_name || 'N/A' %></p>
                <span class="badge <%= b.status %>"><%= b.status %></span>
                <% if (b.status === 'confirmed') { %>
                  <form action="/member/bookings/<%= b.id %>/cancel" method="post">
                    <input type="submit" value="Cancel Booking" class="danger" />
                  </form>
                <% } %>
              </article>
            <% } %>
          </div>
        <% } %>

      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
