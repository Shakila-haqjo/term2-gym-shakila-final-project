<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Bookings Management</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Bookings Management</h2>

        <form action="/admin/bookings" method="get" class="search-form">
          <select name="status">
            <option value="">All statuses</option>
            <option value="confirmed"  <%= statusFilter === 'confirmed'  ? 'selected' : '' %>>Confirmed</option>
            <option value="cancelled"  <%= statusFilter === 'cancelled'  ? 'selected' : '' %>>Cancelled</option>
            <option value="completed"  <%= statusFilter === 'completed'  ? 'selected' : '' %>>Completed</option>
          </select>
          <input type="submit" value="Filter" style="width:auto;" />
          <a href="/admin/bookings" class="link-button" style="width:auto;">Clear</a>
        </form>

        <% if (bookings.length === 0) { %>
          <p>No bookings found.</p>
        <% } else { %>
          <div class="data-list cols-7" style="margin-top:15px;">
            <span class="data-list-heading">Member</span>
            <span class="data-list-heading">Session</span>
            <span class="data-list-heading">Date</span>
            <span class="data-list-heading">Activity</span>
            <span class="data-list-heading">Trainer</span>
            <span class="data-list-heading">Status</span>
            <span class="data-list-heading">Actions</span>
            <% for (const b of bookings) { %>
              <span><%= b.member_name %></span>
              <span><%= b.session_name %></span>
              <span><%= b.session_date %></span>
              <span><%= b.activity_name || 'N/A' %></span>
              <span><%= b.trainer_name || 'N/A' %></span>
              <span class="badge <%= b.status %>"><%= b.status %></span>
              <div class="row-actions">
                <% if (b.status !== 'cancelled') { %>
                  <form action="/admin/bookings/<%= b.id %>" method="post" style="flex:1;">
                    <input type="hidden" name="action" value="cancel" />
                    <input type="submit" value="Cancel" class="danger" />
                  </form>
                <% } %>
                <form action="/admin/bookings/<%= b.id %>" method="post" style="flex:1;">
                  <input type="hidden" name="action" value="delete" />
                  <input type="submit" value="Delete" class="danger" />
                </form>
              </div>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
