<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Admin Dashboard</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Admin Dashboard</h2>

        <h3 style="margin: 15px 0 5px;">Users</h3>
        <div class="stats-row">
          <div class="stat-card"><h3><%= userStats.total %></h3><p>Total Users</p></div>
          <div class="stat-card"><h3><%= userStats.members %></h3><p>Members</p></div>
          <div class="stat-card"><h3><%= userStats.trainers %></h3><p>Trainers</p></div>
          <div class="stat-card"><h3><%= userStats.active %></h3><p>Active</p></div>
        </div>

        <h3 style="margin: 15px 0 5px;">Sessions</h3>
        <div class="stats-row">
          <div class="stat-card"><h3><%= sessionStats.total %></h3><p>Total Sessions</p></div>
          <div class="stat-card"><h3><%= sessionStats.upcoming %></h3><p>Upcoming</p></div>
          <div class="stat-card"><h3><%= sessionStats.totalBookings %></h3><p>Confirmed Bookings</p></div>
          <div class="stat-card"></div>
        </div>

        <h3 style="margin: 15px 0 5px;">Bookings</h3>
        <div class="stats-row">
          <div class="stat-card"><h3><%= bookingStats.total %></h3><p>Total Bookings</p></div>
          <div class="stat-card"><h3><%= bookingStats.confirmed %></h3><p>Confirmed</p></div>
          <div class="stat-card"><h3><%= bookingStats.cancelled %></h3><p>Cancelled</p></div>
          <div class="stat-card"><h3><%= bookingStats.completed %></h3><p>Completed</p></div>
        </div>

        <h3 class="section-heading">Quick Links</h3>
        <div style="display:flex; gap:15px; flex-wrap:wrap;">
          <a href="/admin/users"      class="link-button" style="width:auto; padding:8px 20px;">Manage Users</a>
          <a href="/admin/sessions"   class="link-button" style="width:auto; padding:8px 20px;">Manage Sessions</a>
          <a href="/admin/bookings"   class="link-button" style="width:auto; padding:8px 20px;">Manage Bookings</a>
          <a href="/admin/activities" class="link-button" style="width:auto; padding:8px 20px;">Manage Activities</a>
          <a href="/admin/locations"  class="link-button" style="width:auto; padding:8px 20px;">Manage Locations</a>
          <a href="/admin/blogs"      class="link-button" style="width:auto; padding:8px 20px;">Manage Blogs</a>
        </div>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
