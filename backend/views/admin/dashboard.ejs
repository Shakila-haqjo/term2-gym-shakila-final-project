<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Admin Dashboard</title>
  </head>

  <body>
    <main>
      <%- include("../partials/header.ejs") %>

      <section class="page-content">
        <h2 class="section-heading">Admin Dashboard</h2>

        <!-- USERS -->
        <h3 style="margin: 15px 0 5px;">Users</h3>
        <div class="stats-row">

          <a href="/admin/users" class="stat-link">
            <div class="stat-card">
              <h3><%= userStats.total %></h3>
              <p>All Users</p>
            </div>
          </a>

          <a href="/admin/users?role=member" class="stat-link">
            <div class="stat-card">
              <h3><%= userStats.members %></h3>
              <p>Members</p>
            </div>
          </a>

          <a href="/admin/users?role=trainer" class="stat-link">
            <div class="stat-card">
              <h3><%= userStats.trainers %></h3>
              <p>Trainers</p>
            </div>
          </a>

          <a href="/admin/users?status=active" class="stat-link">
            <div class="stat-card">
              <h3><%= userStats.active %></h3>
              <p>Active</p>
            </div>
          </a>

          <a href="/admin/users?status=inactive" class="stat-link">
            <div class="stat-card">
              <h3><%= userStats.inactive %></h3>
              <p>Inactive</p>
            </div>
          </a>

        </div>

        <!-- SESSIONS -->
        <h3 style="margin: 15px 0 5px;">Sessions</h3>
        <div class="stats-row">

          <a href="/admin/sessions" class="stat-link">
            <div class="stat-card">
              <h3><%= sessionStats.total %></h3>
              <p>All Sessions</p>
            </div>
          </a>

          <a href="/admin/sessions?date=upcoming" class="stat-link">
            <div class="stat-card">
              <h3><%= sessionStats.upcoming %></h3>
              <p>Upcoming</p>
            </div>
          </a>

          <a href="/admin/bookings?status=confirmed" class="stat-link">
            <div class="stat-card">
              <h3><%= sessionStats.totalBookings %></h3>
              <p>Confirmed Bookings</p>
            </div>
          </a>

        </div>

        <!-- BOOKINGS -->
        <h3 style="margin: 15px 0 5px;">Bookings</h3>
        <div class="stats-row">

          <a href="/admin/bookings" class="stat-link">
            <div class="stat-card">
              <h3><%= bookingStats.total %></h3>
              <p>All Bookings</p>
            </div>
          </a>

          <a href="/admin/bookings?status=confirmed" class="stat-link">
            <div class="stat-card">
              <h3><%= bookingStats.confirmed %></h3>
              <p>Confirmed</p>
            </div>
          </a>

          <a href="/admin/bookings?status=cancelled" class="stat-link">
            <div class="stat-card">
              <h3><%= bookingStats.cancelled %></h3>
              <p>Cancelled</p>
            </div>
          </a>

          <a href="/admin/bookings?status=completed" class="stat-link">
            <div class="stat-card">
              <h3><%= bookingStats.completed %></h3>
              <p>Completed</p>
            </div>
          </a>

        </div>

        <!-- ACTIVITIES -->
        <h3 style="margin: 15px 0 5px;">Activities</h3>
        <div class="stats-row">

          <a href="/admin/activities" class="stat-link">
            <div class="stat-card">
              <h3><%= activityStats.total %></h3>
              <p>Total Activities</p>
            </div>
          </a>

          <a href="/admin/activities?status=active" class="stat-link">
            <div class="stat-card">
              <h3><%= activityStats.active %></h3>
              <p>Active</p>
            </div>
          </a>

          <a href="/admin/activities?status=inactive" class="stat-link">
            <div class="stat-card">
              <h3><%= activityStats.inactive %></h3>
              <p>Inactive</p>
            </div>
          </a>

        </div>

        <!-- LOCATIONS -->
        <h3 style="margin: 15px 0 5px;">Locations</h3>
        <div class="stats-row">

          <a href="/admin/locations" class="stat-link">
            <div class="stat-card">
              <h3><%= locationStats.total %></h3>
              <p>Total Locations</p>
            </div>
          </a>

          <a href="/admin/locations?status=active" class="stat-link">
            <div class="stat-card">
              <h3><%= locationStats.active %></h3>
              <p>Active</p>
            </div>
          </a>

          <a href="/admin/locations?status=inactive" class="stat-link">
            <div class="stat-card">
              <h3><%= locationStats.inactive %></h3>
              <p>Inactive</p>
            </div>
          </a>

        </div>

        <!-- BLOGS -->
        <h3 style="margin: 15px 0 5px;">Blogs</h3>
        <div class="stats-row">

          <a href="/admin/blogs" class="stat-link">
            <div class="stat-card">
              <h3><%= blogStats.total %></h3>
              <p>Total Blogs</p>
            </div>
          </a>

          <a href="/admin/blogs?status=published" class="stat-link">
            <div class="stat-card">
              <h3><%= blogStats.published %></h3>
              <p>Published</p>
            </div>
          </a>

          <a href="/admin/blogs?status=draft" class="stat-link">
            <div class="stat-card">
              <h3><%= blogStats.draft %></h3>
              <p>Draft</p>
            </div>
          </a>

        </div>

      </section>

      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>