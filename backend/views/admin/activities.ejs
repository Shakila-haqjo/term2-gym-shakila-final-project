<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Activities Management</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Activities Management</h2>

        <div class="half-half-layout">
          <!-- Activity list -->
          <section class="data-list cols-4">
            <span class="data-list-heading">Name</span>
            <span class="data-list-heading">Description</span>
            <span class="data-list-heading">Status</span>
            <span class="data-list-heading"></span>
            <% for (const activity of activities) { %>
              <span><%= activity.name %></span>
              <span><%= activity.description || '' %></span>
              <span class="badge <%= activity.status %>"><%= activity.status %></span>
              <a href="/admin/activities/<%= activity.id %>" class="link-button">Edit</a>
            <% } %>
          </section>

          <!-- Create / Edit form -->
          <% const editActivity = selected; %>
          <form action="/admin/activities/<%= editActivity ? editActivity.id : '' %>" method="post" class="form-grid">
            <h3 class="two-col"><%= editActivity ? 'Edit Activity' : 'Create New Activity' %></h3>

            <label for="name">Name:</label>
            <input type="text" name="name" id="name" value="<%= editActivity ? editActivity.name : '' %>" required />

            <label for="description">Description:</label>
            <textarea name="description" id="description"><%= editActivity ? (editActivity.description || '') : '' %></textarea>

            <label for="status">Status:</label>
            <select name="status" id="status">
              <option value="active"   <%= !editActivity || editActivity.status === 'active'   ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= editActivity && editActivity.status === 'inactive'  ? 'selected' : '' %>>Inactive</option>
            </select>

            <a href="/admin/activities" class="link-button two-col">Clear</a>

            <% if (!editActivity) { %>
              <input type="submit" name="action" value="create" class="two-col" />
            <% } else { %>
              <input type="submit" name="action" value="update" class="two-col" />
              <input type="submit" name="action" value="delete" class="two-col danger" />
            <% } %>
          </form>
        </div>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
