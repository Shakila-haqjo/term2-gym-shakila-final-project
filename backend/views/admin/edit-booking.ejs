<!DOCTYPE html>
<html>
<head>
  <%- include("../partials/head.ejs") %>
  <title>FitGym - Edit Booking</title>
</head>

<body>
<main>

  <%- include("../partials/header.ejs") %>

  <section class="page-content">

    <h2 class="section-heading">
      Edit Booking
    </h2>

    <form
      action="/admin/bookings/<%= booking.id %>"
      method="post"
      class="form-grid responsive-half margin-auto"
    >

      <input type="hidden" name="action" value="update">

      <label>Member</label>

      <select name="user_id" required>
        <% users.forEach(user => { %>

          <option
            value="<%= user.id %>"
            <%= booking.user_id == user.id ? 'selected' : '' %>
          >
            <%= user.name %>
          </option>

        <% }) %>
      </select>

      <label>Session</label>

      <select name="session_id" required>
        <% sessions.forEach(session => { %>

          <option
            value="<%= session.id %>"
            <%= booking.session_id == session.id ? 'selected' : '' %>
          >
            <%= session.name %>
          </option>

        <% }) %>
      </select>

      <label>Status</label>

      <select name="status">

        <option value="confirmed"
          <%= booking.status === 'confirmed' ? 'selected' : '' %>>
          Confirmed
        </option>

        <option value="cancelled"
          <%= booking.status === 'cancelled' ? 'selected' : '' %>>
          Cancelled
        </option>

        <option value="completed"
          <%= booking.status === 'completed' ? 'selected' : '' %>>
          Completed
        </option>

      </select>

      <a href="/admin/bookings"
         class="link-button">
         Cancel
      </a>

      <input
        type="submit"
        value="Update Booking"
      />

    </form>

  </section>

  <%- include("../partials/footer.ejs") %>

</main>
</body>
</html>