<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Sessions Management</title>
  </head>

  <body>
    <main>
      <%- include("../partials/header.ejs") %>

      <section class="page-content">
        <h2 class="section-heading">Sessions Management</h2>

        <!-- ERROR MESSAGE -->
       <% if (typeof error !== 'undefined' && error) { %>
    <div
      style="
        background:#fee2e2;
        color:#b91c1c;
        border:1px solid #fecaca;
        padding:12px;
        border-radius:6px;
        margin-bottom:15px;
        font-weight:600;
      "
    >
      <%= error %>
    </div>
  <% } %>
         
        <!-- FILTER FORM -->
        <form action="/admin/sessions" method="get" class="search-form">
          <input 
            type="text" 
            name="search" 
            placeholder="Search sessions..." 
            value="<%= search %>" 
          />

          <input 
            type="date" 
            name="date" 
            value="<%= dateFilter %>" 
          />

          <input type="submit" value="Filter" style="width:auto;" />
          <a href="/admin/sessions" class="link-button" style="width:auto;">Clear</a>
        </form>

        <div class="half-half-layout">

          <!-- ===================== -->
          <!-- SESSION LIST -->
          <!-- ===================== -->
          <section class="data-list cols-4">
            <span class="data-list-heading">Name</span>
            <span class="data-list-heading">Date</span>
            <span class="data-list-heading">Trainer</span>
            <span class="data-list-heading">Actions</span>

            <% for (const session of sessions) { %>
              <span><%= session.name %></span>

              <!-- SHOW ONLY DAY / MONTH / YEAR -->
              <span><%= formatDate(session.date) %></span>

              <span><%= session.trainer_name || 'N/A' %></span>

              <div class="row-actions">
                <a href="/admin/sessions/<%= session.id %>" class="link-button" style="flex:1;">
                  Edit
                </a>

                <form action="/admin/sessions/<%= session.id %>" method="post">
                      <input type="hidden" name="action" value="delete" />
                      <input 
                        type="submit" 
                        value="Delete" 
                        class="danger"
                        data-confirm="Are you sure you want to delete this session" 
                      />
                    </form>
                </form>
              </div>
            <% } %>
          </section>

          <!-- ===================== -->
          <!-- CREATE / EDIT FORM -->
          <!-- ===================== -->
          <% const editSession = selected; %>

          <form 
            action="/admin/sessions/<%= editSession ? editSession.id : '' %>" 
            method="post" 
            class="form-grid"
          >
            <h3 class="two-col">
              <%= editSession ? 'Edit Session' : 'Create New Session' %>
            </h3>

            <!-- NAME -->
            <label>Name:</label>
            <input 
              type="text" 
              name="name" 
              value="<%= editSession ? editSession.name : '' %>" 
              required 
            />

            <!-- ACTIVITY -->
            <label>Activity:</label>
            <select name="activity_id">
              <option value="">-- None --</option>
              <% for (const a of activities) { %>
                <option 
                  value="<%= a.id %>" 
                  <%= editSession && editSession.activity_id == a.id ? 'selected' : '' %>
                >
                  <%= a.name %>
                </option>
              <% } %>
            </select>

            <!-- LOCATION -->
            <label>Location:</label>
            <select name="location_id">
              <option value="">-- None --</option>
              <% for (const l of locations) { %>
                <option 
                  value="<%= l.id %>" 
                  <%= editSession && editSession.location_id == l.id ? 'selected' : '' %>
                >
                  <%= l.name %>
                </option>
              <% } %>
            </select>

            <!-- TRAINER -->
            <label>Trainer:</label>
            <select name="trainer_id">
              <option value="">-- None --</option>
              <% for (const t of trainers) { %>
                <option 
                  value="<%= t.id %>" 
                  <%= editSession && editSession.trainer_id == t.id ? 'selected' : '' %>
                >
                  <%= t.name %>
                </option>
              <% } %>
            </select>

            <!-- DATE (FIXED) -->
            <label>Date:</label>
            <input 
              type="date" 
              name="date"
              min="<%= new Date().toISOString().split('T')[0] %>"
              value="<%= editSession && editSession.date 
                ? new Date(new Date(editSession.date).getTime() - new Date(editSession.date).getTimezoneOffset()*60000)
                    .toISOString().split('T')[0] 
                : '' %>" 
              required 
            />

            <!-- TIME -->
            <label>Time:</label>
            <input 
              type="time" 
              name="time"
              value="<%= editSession && editSession.time ? editSession.time.slice(0,5) : '' %>" 
              required 
            />

            <!-- DURATION -->
            <label>Duration (min):</label>
            <input 
              type="number" 
              name="duration_minutes"
              value="<%= editSession ? editSession.duration_minutes : 60 %>" 
              min="1" 
            />

            <!-- MAX PARTICIPANTS -->
            <label>Max Participants:</label>
            <input 
              type="number" 
              name="max_participants"
              value="<%= editSession ? editSession.max_participants : 20 %>" 
              min="1" 
            />

            <!-- DESCRIPTION -->
            <label>Description:</label>
            <textarea name="description"><%= editSession ? (editSession.description || '') : '' %></textarea>

            <!-- BUTTONS -->
            <a href="/admin/sessions" class="link-button two-col">Clear</a>

            <% if (!editSession) { %>
              <input type="submit" name="action" value="create" class="two-col" />
            <% } else { %>
              <input type="submit" name="action" value="update" class="two-col" />
              <input 
                type="submit" 
                name="action" 
                value="delete" 
                class="two-col danger"
                onclick="return confirm('Delete this session?')"
              />
            <% } %>

          </form>
        </div>
      </section>

      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>