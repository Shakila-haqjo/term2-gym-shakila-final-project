<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Sessions Management</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Sessions Management</h2>

        <form action="/admin/sessions" method="get" class="search-form">
          <input type="text" name="search" placeholder="Search sessions..." value="<%= search %>" />
          <input type="date" name="date" value="<%= dateFilter %>" />
          <input type="submit" value="Filter" style="width:auto;" />
          <a href="/admin/sessions" class="link-button" style="width:auto;">Clear</a>
        </form>

        <div class="half-half-layout">
          <!-- Session list -->
          <section class="data-list cols-4">
            <span class="data-list-heading">Name</span>
            <span class="data-list-heading">Date</span>
            <span class="data-list-heading">Trainer</span>
            <span class="data-list-heading"></span>
            <% for (const session of sessions) { %>
              <span><%= session.name %></span>
              <span><%= session.date %></span>
              <span><%= session.trainer_name || 'N/A' %></span>
              <a href="/admin/sessions/<%= session.id %>" class="link-button">Edit</a>
            <% } %>
          </section>

          <!-- Create / Edit form -->
          <% const editSession = selected; %>
          <form action="/admin/sessions/<%= editSession ? editSession.id : '' %>" method="post" class="form-grid">
            <h3 class="two-col"><%= editSession ? 'Edit Session' : 'Create New Session' %></h3>

            <label for="name">Name:</label>
            <input type="text" name="name" id="name" value="<%= editSession ? editSession.name : '' %>" required />

            <label for="activity_id">Activity:</label>
            <select name="activity_id" id="activity_id">
              <option value="">-- None --</option>
              <% for (const a of activities) { %>
                <option value="<%= a.id %>" <%= editSession && editSession.activity_id == a.id ? 'selected' : '' %>><%= a.name %></option>
              <% } %>
            </select>

            <label for="location_id">Location:</label>
            <select name="location_id" id="location_id">
              <option value="">-- None --</option>
              <% for (const l of locations) { %>
                <option value="<%= l.id %>" <%= editSession && editSession.location_id == l.id ? 'selected' : '' %>><%= l.name %></option>
              <% } %>
            </select>

            <label for="trainer_id">Trainer:</label>
            <select name="trainer_id" id="trainer_id">
              <option value="">-- None --</option>
              <% for (const t of trainers) { %>
                <option value="<%= t.id %>" <%= editSession && editSession.trainer_id == t.id ? 'selected' : '' %>><%= t.name %></option>
              <% } %>
            </select>

            <label for="date">Date:</label>
            <input type="date" name="date" id="date" value="<%= editSession ? editSession.date : '' %>" required />

            <label for="time">Time:</label>
            <input type="time" name="time" id="time" value="<%= editSession ? (editSession.time ? editSession.time.slice(0,5) : '') : '' %>" required />

            <label for="duration_minutes">Duration (min):</label>
            <input type="number" name="duration_minutes" id="duration_minutes" value="<%= editSession ? editSession.duration_minutes : 60 %>" min="1" />

            <label for="max_participants">Max Participants:</label>
            <input type="number" name="max_participants" id="max_participants" value="<%= editSession ? editSession.max_participants : 20 %>" min="1" />

            <label for="description">Description:</label>
            <textarea name="description" id="description"><%= editSession ? (editSession.description || '') : '' %></textarea>

            <a href="/admin/sessions" class="link-button two-col">Clear</a>

            <% if (!editSession) { %>
              <input type="submit" name="action" value="create" class="two-col" />
            <% } else { %>
              <input type="submit" name="action" value="update" class="two-col" />
              <input type="submit" name="action" value="delete" class="two-col danger" />
            <% } %>
          </form>
        </div>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
