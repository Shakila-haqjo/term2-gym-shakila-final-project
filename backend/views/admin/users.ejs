<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - User Management</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">User Management</h2>

        <!-- Search / filter -->
        <form action="/admin/users" method="get" class="search-form">
          <input type="text" name="search" placeholder="Search name or email..." value="<%= search %>" />
          <select name="role">
            <option value="">All roles</option>
            <option value="admin"   <%= roleFilter === 'admin'   ? 'selected' : '' %>>Admin</option>
            <option value="trainer" <%= roleFilter === 'trainer' ? 'selected' : '' %>>Trainer</option>
            <option value="member"  <%= roleFilter === 'member'  ? 'selected' : '' %>>Member</option>
          </select>
          <select name="status">
            <option value="">All statuses</option>
            <option value="active"   <%= statusFilter === 'active'   ? 'selected' : '' %>>Active</option>
            <option value="inactive" <%= statusFilter === 'inactive' ? 'selected' : '' %>>Inactive</option>
          </select>
          <input type="submit" value="Filter" style="width:auto;" />
          <a href="/admin/users" class="link-button" style="width:auto;">Clear</a>
        </form>

        <div class="half-half-layout">
          <!-- User list -->
          <section class="data-list cols-5">
            <span class="data-list-heading">Name</span>
            <span class="data-list-heading">Email</span>
            <span class="data-list-heading">Role</span>
            <span class="data-list-heading">Status</span>
            <span class="data-list-heading">Actions</span>
            <% for (const user of users) { %>
              <span><%= user.name %></span>
              <span><%= user.email %></span>
              <span><%= user.role %></span>
              <span class="badge <%= user.status %>"><%= user.status %></span>
              <div class="row-actions">
                <a href="/admin/users/<%= user.id %>" class="link-button" style="flex:1;">Edit</a>
                <form action="/admin/users/<%= user.id %>" method="post" style="flex:1;">
                  <input type="hidden" name="action" value="delete" />
                  <input type="submit" value="Delete" class="danger"
                    data-confirm="Are you sure you want to delete &quot;<%= user.name %>&quot;?" />
                </form>
              </div>
            <% } %>
          </section>

          <!-- Create / Edit form -->
          <% const editUser = selected; %>
          <form action="/admin/users/<%= editUser ? editUser.id : '' %>" method="post" class="form-grid">
            <h3 class="two-col"><%= editUser ? 'Edit User' : 'Create New User' %></h3>

            <label for="name">Name:</label>
            <input type="text" name="name" id="name" value="<%= editUser ? editUser.name : '' %>" />

            <label for="email">Email:</label>
            <input type="email" name="email" id="email" value="<%= editUser ? editUser.email : '' %>" />

            <label for="phone">Phone:</label>
            <input type="text" name="phone" id="phone" value="<%= editUser ? (editUser.phone || '') : '' %>" />

            <label for="address">Address:</label>
            <input type="text" name="address" id="address" value="<%= editUser ? (editUser.address || '') : '' %>" />

            <label for="role">Role:</label>
            <select name="role" id="role">
              <option value="member"  <%= editUser && editUser.role === 'member'  ? 'selected' : '' %>>Member</option>
              <option value="trainer" <%= editUser && editUser.role === 'trainer' ? 'selected' : '' %>>Trainer</option>
              <option value="admin"   <%= editUser && editUser.role === 'admin'   ? 'selected' : '' %>>Admin</option>
            </select>

            <label for="status">Status:</label>
            <select name="status" id="status">
              <option value="active"   <%= !editUser || editUser.status === 'active'   ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= editUser && editUser.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
            </select>

            <label for="password">Password:</label>
            <input type="password" name="password" id="password" placeholder="<%= editUser ? 'Leave blank to keep current' : 'Required' %>" <%= editUser ? '' : 'required' %> />

            <a href="/admin/users" class="link-button two-col">Clear</a>

            <% if (!editUser) { %>
              <input type="submit" name="action" value="create" class="two-col" />
            <% } else { %>
              <input type="submit" name="action" value="update" class="two-col" />
              <input type="submit" name="action" value="delete" class="two-col danger"
                data-confirm="Are you sure you want to delete this user? This cannot be undone." />
            <% } %>
          </form>
        </div>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
