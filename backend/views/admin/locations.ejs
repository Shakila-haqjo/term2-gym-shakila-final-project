<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Locations Management</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Locations Management</h2>

        <div class="half-half-layout">
          <!-- Location list -->
          <section class="data-list cols-4">
            <span class="data-list-heading">Name</span>
            <span class="data-list-heading">Address</span>
            <span class="data-list-heading">Status</span>
            <span class="data-list-heading">Actions</span>
            <% for (const location of locations) { %>
              <span><%= location.name %></span>
              <span><%= location.address || '' %></span>
              <span class="badge <%= location.status %>"><%= location.status %></span>
              <div class="row-actions">
                <a href="/admin/locations/<%= location.id %>" class="link-button" style="flex:1;">Edit</a>
                <form action="/admin/locations/<%= location.id %>" method="post" style="flex:1;">
                  <input type="hidden" name="action" value="delete" />
                  <input type="submit" value="Delete" class="danger"
                    onclick="return confirm('Are you sure you want to delete &quot;<%= location.name %>&quot;?')" />
                </form>
              </div>
            <% } %>
          </section>

          <!-- Create / Edit form -->
          <% const editLocation = selected; %>
          <form action="/admin/locations/<%= editLocation ? editLocation.id : '' %>" method="post" class="form-grid">
            <h3 class="two-col"><%= editLocation ? 'Edit Location' : 'Create New Location' %></h3>

            <label for="name">Name:</label>
            <input type="text" name="name" id="name" value="<%= editLocation ? editLocation.name : '' %>" required />

            <label for="address">Address:</label>
            <input type="text" name="address" id="address" value="<%= editLocation ? (editLocation.address || '') : '' %>" />

            <label for="capacity">Capacity:</label>
            <input type="number" name="capacity" id="capacity" value="<%= editLocation ? (editLocation.capacity || '') : '' %>" min="1" />

            <label for="status">Status:</label>
            <select name="status" id="status">
              <option value="active"   <%= !editLocation || editLocation.status === 'active'   ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= editLocation && editLocation.status === 'inactive'  ? 'selected' : '' %>>Inactive</option>
            </select>

            <a href="/admin/locations" class="link-button two-col">Clear</a>

            <% if (!editLocation) { %>
              <input type="submit" name="action" value="create" class="two-col" />
            <% } else { %>
              <input type="submit" name="action" value="update" class="two-col" />
              <input type="submit" name="action" value="delete" class="two-col danger"
                onclick="return confirm('Are you sure you want to delete this location? This cannot be undone.')" />
            <% } %>
          </form>
        </div>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
