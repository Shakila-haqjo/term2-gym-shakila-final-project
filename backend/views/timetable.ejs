<!DOCTYPE html>
<html>
  <head>
    <%- include("partials/head.ejs") %>
    <title>FitGym - Timetable</title>
  </head>
  <body>
    <main>
      <%- include("partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Upcoming Sessions</h2>

        <% if (sessions.length === 0) { %>
          <p>No upcoming sessions scheduled.</p>
        <% } else { %>
          <div class="card-list">
            <% for (const session of sessions) { %>
              <article class="card">
                <h3><%= session.name %></h3>
                <p>Date: <strong><%= session.date %></strong> at <strong><%= session.time ? session.time.slice(0,5) : '' %></strong></p>
                <p>Activity: <%= session.activity_name || 'N/A' %></p>
                <p>Location: <%= session.location_name || 'N/A' %></p>
                <p>Trainer: <%= session.trainer_name || 'N/A' %></p>
                <p>Duration: <%= session.duration_minutes %> min &nbsp;|&nbsp; Spots: <%= session.max_participants %></p>
                <% if (session.description) { %><p><%= session.description %></p><% } %>
                <a href="/authenticate/register" class="link-button">Join to Book</a>
              </article>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("partials/footer.ejs") %>
    </main>
  </body>
</html>
