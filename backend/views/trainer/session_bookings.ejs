<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Session Bookings</title>
  </head>

  <body>
    <main>
      <%- include("../partials/header.ejs") %>

      <section class="page-content">

        <h2 class="section-heading">
          Bookings for: <%= session.name %>
        </h2>

        <p>
          <strong>Date:</strong> <%= formatDate(session.date) %>
          &nbsp;|&nbsp;
          <strong>Time:</strong> <%= session.time ? session.time.slice(0,5) : '' %>
        </p>

        <br />

        <a href="/trainer/sessions"
           class="link-button"
           style="width:auto; padding:8px 20px; margin-bottom:15px; display:inline-block;">
          Back to Sessions
        </a>

        <% if (bookings.length === 0) { %>
          <p>No bookings for this session yet.</p>
        <% } else { %>

          <div class="data-list cols-5" style="margin-top:15px;">

            <span class="data-list-heading">Member</span>
            <span class="data-list-heading">Email</span>
            <span class="data-list-heading">Phone</span>
            <span class="data-list-heading">Status</span>
            <span class="data-list-heading">Action</span>

         <% for (const b of bookings) { %>
  <span><%= b.member_name %></span>
  <span><%= b.member_email %></span>
  <span><%= b.member_phone || 'N/A' %></span>

  <!-- ✅ EDITABLE STATUS -->
  <form action="/trainer/bookings/<%= b.id %>" method="POST" style="display:flex; gap:6px;">

    <select name="status">
      <option value="confirmed" <%= b.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
      <option value="cancelled" <%= b.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
      <option value="completed" <%= b.status === 'completed' ? 'selected' : '' %>>Completed</option>
    </select>

    <input type="submit" value="Update" style="width:auto;" />

  </form>
<% } %>

          </div>

        <% } %>

      </section>

      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>