<div id="alertBox"></div>
<div style="max-width:720px;">
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-plus-circle" style="color:var(--accent-gold)"></i> New Training Session</span>
      <a href="/trainer/sessions" class="btn btn-sm btn-secondary"><i class="fas fa-list"></i> My Sessions</a>
    </div>
    <div class="card-body">
      <form id="createSessionForm">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Activity Type</label>
            <select id="activity_id" class="form-control">
              <option value="">Select activity...</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Location</label>
            <select id="location_id" class="form-control">
              <option value="">Select location...</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Date *</label>
            <input type="date" id="date" class="form-control" required>
          </div>
          <div class="form-group">
            <label class="form-label">Time *</label>
            <input type="time" id="time" class="form-control" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Duration (minutes)</label>
            <input type="number" id="duration_minutes" class="form-control" value="60" min="15" max="240">
          </div>
          <div class="form-group">
            <label class="form-label">Max Participants</label>
            <input type="number" id="max_participants" class="form-control" value="20" min="1" max="200">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea id="description" class="form-control" placeholder="Describe the session goals, requirements, what to bring..."></textarea>
        </div>
        <div style="display:flex;gap:10px;">
          <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Create Session</button>
          <a href="/trainer/sessions" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
