<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Trainer Dashboard</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">Welcome, <%= authenticatedUser.name %>!</h2>

        <div class="stats-row">
          <div class="stat-card"><h3><%= stats.total %></h3><p>Total Sessions</p></div>
          <div class="stat-card"><h3><%= stats.upcoming %></h3><p>Upcoming</p></div>
          <div class="stat-card"><h3><%= stats.totalBookings %></h3><p>Confirmed Bookings</p></div>
          <div class="stat-card"></div>
        </div>

        <h3 style="margin: 15px 0 5px;">Upcoming Sessions</h3>
        <% if (sessions.length === 0) { %>
          <p>No upcoming sessions. <a href="/trainer/sessions/create">Create one</a>.</p>
        <% } else { %>
          <div class="card-list">
            <% for (const session of sessions) { %>
              <article class="card">
                <h3><%= session.name %></h3>
                <p>Date: <strong><%= session.date %></strong> at <strong><%= session.time ? session.time.slice(0,5) : '' %></strong></p>
                <p>Activity: <%= session.activity_name || 'N/A' %></p>
                <p>Location: <%= session.location_name || 'N/A' %></p>
                <p>Booked: <%= session.booked_count %> / <%= session.max_participants %></p>
                <div class="row-actions">
                  <a href="/trainer/sessions/<%= session.id %>/edit" class="link-button">Edit</a>
                  <a href="/trainer/sessions/<%= session.id %>/bookings" class="link-button">Bookings</a>
                </div>
              </article>
            <% } %>
          </div>
        <% } %>

        <div style="display:flex; gap:15px; margin-top:20px;">
          <a href="/trainer/sessions"        class="link-button" style="width:auto; padding:8px 20px;">All My Sessions</a>
          <a href="/trainer/sessions/create" class="link-button" style="width:auto; padding:8px 20px;">Create Session</a>
          <a href="/trainer/blog"            class="link-button" style="width:auto; padding:8px 20px;">My Blog Posts</a>
        </div>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
