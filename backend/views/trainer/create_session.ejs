<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Create Session</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <form action="/trainer/sessions" method="post" class="form-grid responsive-half margin-auto">
          <h2 class="two-col">Create New Session</h2>

          <% if (error) { %>
            <p class="two-col" style="color:darkred;"><%= error %></p>
          <% } %>

          <label for="name">Session Name:</label>
          <input type="text" name="name" id="name" required />

          <label for="activity_id">Activity:</label>
          <select name="activity_id" id="activity_id">
            <option value="">-- None --</option>
            <% for (const a of activities) { %>
              <option value="<%= a.id %>"><%= a.name %></option>
            <% } %>
          </select>

          <label for="location_id">Location:</label>
          <select name="location_id" id="location_id">
            <option value="">-- None --</option>
            <% for (const l of locations) { %>
              <option value="<%= l.id %>"><%= l.name %></option>
            <% } %>
          </select>

          <label for="date">Date:</label>
          <input type="date" name="date" id="date" required />

          <label for="time">Time:</label>
          <input type="time" name="time" id="time" required />

          <label for="duration_minutes">Duration (min):</label>
          <input type="number" name="duration_minutes" id="duration_minutes" value="60" min="1" />

          <label for="max_participants">Max Participants:</label>
          <input type="number" name="max_participants" id="max_participants" value="20" min="1" />

          <label for="description">Description:</label>
          <textarea name="description" id="description"></textarea>

          <a href="/trainer/sessions" class="link-button two-col">Cancel</a>
          <input type="submit" value="Create Session" class="two-col" />
        </form>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
