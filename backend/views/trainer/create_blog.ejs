<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Write Blog Post</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <form action="/trainer/blog" method="post" class="form-grid responsive-half margin-auto">
          <h2 class="two-col">Write a Blog Post</h2>

          <% if (error) { %>
            <p class="two-col" style="color:darkred;"><%= error %></p>
          <% } %>

          <label for="title">Title:</label>
          <input type="text" name="title" id="title" required />

          <label for="category">Category:</label>
          <input type="text" name="category" id="category" placeholder="e.g. Fitness, Nutrition..." />

          <label for="content">Content:</label>
          <textarea name="content" id="content" style="height:10em;"></textarea>

          <label for="status">Status:</label>
          <select name="status" id="status">
            <option value="draft">Draft</option>
            <option value="published">Published</option>
          </select>

          <a href="/trainer/blog" class="link-button two-col">Cancel</a>
          <input type="submit" value="Save Post" class="two-col" />
        </form>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
