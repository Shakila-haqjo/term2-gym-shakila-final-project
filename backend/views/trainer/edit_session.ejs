<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Edit Session</title>
  </head>

  <body>
    <main>
      <%- include("../partials/header.ejs") %>

      <section class="page-content">

        <form action="/trainer/sessions/<%= session.id %>" method="post"
              class="form-grid responsive-half margin-auto">

          <h2 class="two-col">Edit Session</h2>

          <% if (error) { %>
            <p class="two-col" style="color: darkred;">
              <%= error %>
            </p>
          <% } %>

          <!-- SESSION NAME -->
          <label for="name">Session Name:</label>
          <input type="text" name="name" id="name"
                 value="<%= session.name %>" required />

          <!-- ACTIVITY -->
          <label for="activity_id">Activity:</label>
          <select name="activity_id" id="activity_id">
            <option value="">-- None --</option>
            <% activities.forEach(a => { %>
              <option value="<%= a.id %>"
                <%= session.activity_id == a.id ? 'selected' : '' %>>
                <%= a.name %>
              </option>
            <% }) %>
          </select>

          <!-- LOCATION -->
          <label for="location_id">Location:</label>
          <select name="location_id" id="location_id">
            <option value="">-- None --</option>
            <% locations.forEach(l => { %>
              <option value="<%= l.id %>"
                <%= session.location_id == l.id ? 'selected' : '' %>>
                <%= l.name %>
              </option>
            <% }) %>
          </select>

          <!-- DATE -->
          <label for="date">Date:</label>
          <!-- <input type="date" name="date" id="date"
                 value="<%= formatDate(session.date) %>" required /> -->
     

<input 
  type="date" 
  name="date" 
  id="date"
  min="<%= new Date().toISOString().split('T')[0] %>"
  value="<%= session && session.date 
    ? new Date(new Date(session.date).getTime() - new Date(session.date).getTimezoneOffset()*60000)
        .toISOString()
        .split('T')[0] 
    : '' %>" 
  required 
/>

          <!-- TIME -->
          <label for="time">Time:</label>
          <input type="time" name="time" id="time"
                 value="<%= session.time ? session.time.slice(0,5) : '' %>" required />

          <!-- DURATION -->
          <label for="duration_minutes">Duration (min):</label>
          <input type="number" name="duration_minutes" id="duration_minutes"
                 value="<%= session.duration_minutes %>" min="1" />

          <!-- MAX PARTICIPANTS -->
          <label for="max_participants">Max Participants:</label>
          <input type="number" name="max_participants" id="max_participants"
                 value="<%= session.max_participants %>" min="1" />

          <!-- DESCRIPTION -->
          <label for="description">Description:</label>
          <textarea name="description" id="description"><%= session.description || '' %></textarea>

          <!-- ACTIONS -->
          <a href="/trainer/sessions"
             class="link-button two-col">
            Cancel
          </a>

          <!-- UPDATE BUTTON -->
          <input type="submit"
                 name="action"
                 value="update"
                 class="two-col" />



        </form>

      </section>

      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>