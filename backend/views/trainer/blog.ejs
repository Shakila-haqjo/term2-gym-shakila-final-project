<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - Blog Posts</title>
  </head>

  <body class="trainer-page">
    <main>
      <%- include("../partials/header.ejs") %>

      <section class="page-content">
        <h2 class="section-heading">All Blog Posts</h2>

        <a href="/trainer/blog/create" class="link-button"
           style="width:auto; padding:8px 20px; margin-bottom:15px; display:inline-block;">
          Write a Post
        </a>

        <% if (blogs.length === 0) { %>
          <p>No blog posts yet.</p>
        <% } else { %>

          <div class="card-list">

            <% for (const blog of blogs) { %>
              <article class="card">

                <h3><%= blog.title %></h3>

                <!-- <p>Category: <%= blog.category || 'N/A' %></p>

                <p>
                  Status:
                  <span class="badge <%= blog.status %>">
                    <%= blog.status %>
                  </span>
                </p> -->

                <p>
                  Created:
                  <strong><%= formatDate(blog.created_at) %></strong>
                </p>

                <div class="row-actions">

                  <!-- READ BUTTON -->
                  <a href="/blog/<%= blog.id %>" class="link-button" style="width:auto;">
                    Read
                  </a>

                  <!-- DELETE ONLY OWN BLOG -->
                  <% if (blog.author_id === authenticatedUser.id) { %>
                    <form action="/trainer/blog/<%= blog.id %>" method="post">
                      <input type="hidden" name="action" value="delete" />
                      <input type="submit" value="Delete" class="danger"
                        data-confirm="Are you sure you want to delete &quot;<%= blog.title %>&quot;?" />
                    </form>
                  <% } %>

                </div>

              </article>
            <% } %>

          </div>

        <% } %>
      </section>

      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>