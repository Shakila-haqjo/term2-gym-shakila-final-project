<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - My Blog Posts</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">My Blog Posts</h2>
        <a href="/trainer/blog/create" class="link-button" style="width:auto; padding:8px 20px; margin-bottom:15px; display:inline-block;">Write a Post</a>

        <% if (blogs.length === 0) { %>
          <p>No blog posts yet.</p>
        <% } else { %>
          <div class="data-list cols-5" style="margin-top:15px;">
            <span class="data-list-heading">Title</span>
            <span class="data-list-heading">Category</span>
            <span class="data-list-heading">Status</span>
            <span class="data-list-heading">Created</span>
            <span class="data-list-heading">Actions</span>
            <% for (const blog of blogs) { %>
              <span><%= blog.title %></span>
              <span><%= blog.category || 'N/A' %></span>
              <span class="badge <%= blog.status %>"><%= blog.status %></span>
              <span><%= blog.created_at ? blog.created_at.slice(0,10) : '' %></span>
              <a href="/trainer/blog/<%= blog.id %>/edit" class="link-button">Edit</a>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
