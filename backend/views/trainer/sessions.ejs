<!DOCTYPE html>
<html>
  <head>
    <%- include("../partials/head.ejs") %>
    <title>FitGym - My Sessions</title>
  </head>
  <body>
    <main>
      <%- include("../partials/header.ejs") %>
      <section class="page-content">
        <h2 class="section-heading">My Sessions</h2>
        <a href="/trainer/sessions/create" class="link-button" style="width:auto; padding:8px 20px; margin-bottom:15px; display:inline-block;">Create New Session</a>

        <form action="/trainer/sessions" method="get" class="search-form">
          <input type="text" name="search" placeholder="Search sessions..." value="<%= search %>" />
          <input type="date" name="date" value="<%= dateFilter %>" />
          <input type="submit" value="Filter" style="width:auto;" />
          <a href="/trainer/sessions" class="link-button" style="width:auto;">Clear</a>
        </form>

        <% if (sessions.length === 0) { %>
          <p>No sessions found.</p>
        <% } else { %>
          <div class="data-list cols-6" style="margin-top:15px;">
            <span class="data-list-heading">Name</span>
            <span class="data-list-heading">Date</span>
            <span class="data-list-heading">Time</span>
            <span class="data-list-heading">Activity</span>
            <span class="data-list-heading">Booked</span>
            <span class="data-list-heading">Actions</span>
            <% for (const session of sessions) { %>
              <span><%= session.name %></span>
              <span><%= session.date %></span>
              <span><%= session.time ? session.time.slice(0,5) : '' %></span>
              <span><%= session.activity_name || 'N/A' %></span>
              <span><%= session.booked_count %> / <%= session.max_participants %></span>
              <div class="row-actions">
                <a href="/trainer/sessions/<%= session.id %>/edit" class="link-button">Edit</a>
                <a href="/trainer/sessions/<%= session.id %>/bookings" class="link-button">Bookings</a>
              </div>
            <% } %>
          </div>
        <% } %>
      </section>
      <%- include("../partials/footer.ejs") %>
    </main>
  </body>
</html>
